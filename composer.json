{
  "name": "orbitconnect/orbit-server-php",
  "description": "OrbitConnect Server SDK for PHP — native cURL, no dependencies",
  "type": "library",
  "license": "MIT",
  "keywords": ["orbitconnect", "sdk", "chat", "messaging", "calls", "meetings", "realtime", "webhooks"],
  "homepage": "https://github.com/core-dynamics/orbit-server-php",
  "support": {
    "issues": "https://github.com/core-dynamics/orbit-server-php/issues",
    "source": "https://github.com/core-dynamics/orbit-server-php"
  },
  "authors": [
    {
      "name": "OrbitConnect",
      "email": "dev@orbitconnect.cloud",
      "homepage": "https://orbitconnect.cloud"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "autoload": {
    "psr-4": {
      "OrbitConnect\\Server\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OrbitConnect\\Server\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
